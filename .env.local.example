# Credenciales del proyecto Supabase del dashboard.
# Copiá este archivo a .env.local (queda en .gitignore) y completá con los
# valores de tu proyecto Supabase (Settings → API → Project URL / anon key).
#
# Vite solo expone variables que empiezan con VITE_ al código del cliente.

VITE_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...
